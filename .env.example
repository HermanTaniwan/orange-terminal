# Required: OpenRouter key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Required: PostgreSQL connection string (with pgvector)
# Example matches docker-compose.yml (port 5433 on host)
DATABASE_URL=postgresql://app:app@localhost:5433/orange_terminal

# Embedding model on OpenRouter — dimension must match db/migrations (1536)
EMBEDDING_MODEL=openai/text-embedding-3-small

# Chat model for RAG answers and insights
CHAT_MODEL=openai/gpt-4o-mini

# Local folder for uploaded files (relative to project root)
UPLOAD_DIR=./uploads

# Max upload size in MB
MAX_UPLOAD_MB=25

# --- IDX ingest (emiten) ---
# Set ke 1 di server tanpa GUI agar Python pakai Chrome headless.
# Kalau headless diblokir IDX, coba tanpa ini dan jalankan app dengan display virtual:
#   xvfb-run -a npm run start
IDX_HEADLESS=

# Detik tunggu setelah buka halaman keterbukaan IDX (challenge / cookie).
IDX_WAIT_SECONDS=10

# Interpreter Python untuk skrip IDX (default: python)
# PYTHON_BIN=python3
